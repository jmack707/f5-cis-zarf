# Credentials — never commit the real file; commit only *.example
credentials.env
.env

# Ansible vault — encrypt before committing, or exclude entirely
# group_vars/all/vault.yaml should be encrypted with ansible-vault
# before being committed. Exclude the unencrypted version as a safety net.
# Uncomment the line below if your team stores encrypted vault files in git:
# group_vars/all/vault.yaml
*.jwt

# Harbor CA cert (site-specific, not project config)
certs/harbor-ca.crt

# Zarf build artifacts
*.tar.zst
*.tar.zst.sha256
*.tar.zst.bundle

# Ansible vault password file if stored locally
.vault-pass
