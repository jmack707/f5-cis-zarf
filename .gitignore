# Credentials — never commit the real file; commit only *.example
credentials.env
.env

# Ansible vault — exclude unencrypted vault file entirely.
# Encrypt with: ansible-vault encrypt group_vars/all/vault.yaml
# If storing the encrypted file in git, comment out the line below.
group_vars/all/vault.yaml

# Harbor CA cert (site-specific, not project config)
certs/harbor-ca.crt

# Zarf build artifacts
*.tar.zst
*.tar.zst.sha256
*.tar.zst.bundle

# Ansible vault password file if stored locally
.vault-pass
