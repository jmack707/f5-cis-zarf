# credentials.env.example
# ---------------------------------------------------------------------------
# Copy this file to credentials.env and fill in your values.
#
#   cp credentials.env.example credentials.env
#   chmod 600 credentials.env
#
# credentials.env is gitignored — never commit the real file.
# create-package.sh sources this automatically if it exists in the project root.
# Values here are overridden by environment variables of the same name if both
# are set, so CI systems can still inject credentials via env without editing
# this file.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Docker Hub
# Use a Personal Access Token (PAT) rather than your account password.
# Create one at: https://hub.docker.com/settings/security
# Minimum scope required: Public Repo Read
# ---------------------------------------------------------------------------
DOCKER_USER="your-dockerhub-username"
DOCKER_PASS="dckr_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# NGINX Plus license
# Paste your JWT token content directly as the value of NGINX_JWT.
# Open your .jwt file, copy everything (the full "eyJ..." string), paste below.
#
# NGINX_JWT also accepts a file path if you prefer to keep the file on disk:
#   NGINX_JWT="/path/to/nginx-repo.jwt"
# The script detects automatically whether the value is a path or token content.
# ---------------------------------------------------------------------------
NGINX_JWT="eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6..."
